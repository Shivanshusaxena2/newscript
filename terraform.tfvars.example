# Copy this file to terraform.tfvars and fill in real values.

location            = "Central US"
resource_group_name = "rg-winvm-demo"

admin_username = "azureadmin"
# admin_password already has a default in variables.tf ("P@ssw0rd1234!").
# Override it here if you want a different one:
# admin_password = "YourOwnP@ssw0rd123!"

# script_raw_url already defaults (in variables.tf) to:
# https://raw.githubusercontent.com/Shivanshusaxena2/terraformtest01/main/setup.ps1
# Only set it here if you want to point at a different repo/script.
# script_raw_url = "https://raw.githubusercontent.com/<user>/<repo>/main/setup.ps1"

# Restrict RDP to your own public IP in real deployments, e.g. "203.0.113.5/32"
allowed_rdp_source_address_prefix = "*"

vm_config = {
  vm1 = { install_iis = true }  # IIS installed here only
  vm2 = { install_iis = false }
}
